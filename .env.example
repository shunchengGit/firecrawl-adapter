# SearXNG 端口（主机端口 -> 容器内 8080）
SEARXNG_PORT=3671

# adapter 监听端口
ADAPTER_HOST=127.0.0.1
ADAPTER_PORT=3672

# adapter 指向 SearXNG 的地址（本地运行时用 127.0.0.1 + SEARXNG_PORT）
SEARXNG_BASE=http://127.0.0.1:3671

# Firecrawl 协议入口（Hermes 指向这里）
FIRECRAWL_API_URL=http://127.0.0.1:3672

# 单次 crawl 最长运行秒数（超时 job 状态变 timeout）
ADAPTER_CRAWL_TIMEOUT=300

# SearXNG 全局代理（容器内用 host.docker.internal 指向宿主机）
# 留空 = 无代理（默认）；设置后 Google/Wikipedia 等被墙引擎才能用
# SEARXNG_PROXY=http://host.docker.internal:7890
